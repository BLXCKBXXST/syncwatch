# Environment variables template.
# Copy to .env and fill in real values (.env is gitignored).
# Without an .env the stack runs on SQLite + in-memory channel layer.

# --- Django ---
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=example.com,localhost,127.0.0.1

# --- Database (production — PostgreSQL; without it — SQLite) ---
DATABASE_URL=postgres://app:app@db:5432/app
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=replace-with-db-password

# --- Redis (channel layer; without it — in-memory) ---
REDIS_URL=redis://redis:6379/0

# --- CORS (frontend origin) ---
CORS_ALLOWED_ORIGINS=https://example.com

# --- Media uploads ---
MEDIA_ROOT=/srv/media
MAX_UPLOAD_SIZE=209715200

# --- Frontend (Vite, build-time) ---
# Empty = relative paths (same origin behind the reverse proxy).
VITE_API_BASE=
VITE_WS_BASE=

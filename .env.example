# Шаблон переменных окружения.
# Скопировать в .env и заполнить реальными значениями (.env в .gitignore).
# Локально без .env стек работает на SQLite + in-memory channel layer.

# --- Django ---
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=example.com,localhost,127.0.0.1

# --- База данных (продакшен — PostgreSQL; без переменной — SQLite) ---
DATABASE_URL=postgres://app:app@db:5432/app
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=replace-with-db-password

# --- Redis (channel layer; без переменной — in-memory) ---
REDIS_URL=redis://redis:6379/0

# --- CORS (origin фронтенда) ---
CORS_ALLOWED_ORIGINS=https://example.com

# --- Медиа и загрузки ---
MEDIA_ROOT=/srv/media
MAX_UPLOAD_SIZE=209715200

# --- Фронтенд (Vite, этап сборки) ---
# Пусто = относительные пути (тот же origin за обратным прокси).
VITE_API_BASE=
VITE_WS_BASE=

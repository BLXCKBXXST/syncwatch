classDiagram
    direction LR

    class User {
      UUID id
      string username
    }
    class Video {
      UUID id
      UUID owner_id
      string title
    }
    class WatchRoom {
      UUID id
      UUID video_id
      UUID host_id
      float playback_position
      bool is_playing
    }
    class ChatMessage {
      UUID id
      UUID room_id
      UUID author_id
      text text
    }
    class Question {
      UUID id
      UUID room_id
      UUID author_id
      bool is_answered
    }

    User "1" --o "*" Video : загружает
    User "1" --o "*" WatchRoom : ведёт
    Video "1" --o "*" WatchRoom : проигрывается
    WatchRoom "1" --o "*" ChatMessage : содержит
    User "1" --o "*" ChatMessage : пишет
    WatchRoom "1" --o "*" Question : содержит
    User "1" --o "*" Question : задаёт
